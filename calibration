import cv2 as cv
import numpy as np
import glob

# 1. 체스판 설정
checkerboard = (11,8)
criteria = (cv.TERM_CRITERIA_EPS + cv.TERM_CRITERIA_MAX_ITER, 30, 0.001)

# 3D 점 준비
objp = np.zeros((1,checkerboard[0] * checkerboard[1], 3), np.float32)
objp[0,:,:2] = np.mgrid[0:checkerboard[0], 0:checkerboard[1]].T.reshape(-1, 2)

# 실제 세계의 3D 점과 이미지상의 2D 점을 저장할 리스트
objpoints = [] # 3d 
imgpoints = [] # 2d 

# 이미지 파일들을 불러옵니다
images = glob.glob('.\claigration\*.jpg')
img = cv.imread('4.jpg')
gray = cv.cvtColor(img, cv.COLOR_BGR2GRAY)

for fname in images:
    img = cv.imread(fname)
    img = cv.resize(img, None, fx=0.3, fy=0.3)
    gray = cv.cvtColor(img, cv.COLOR_BGR2GRAY)

    # 체스판 코너 찾기
    ret, corners = cv.findChessboardCorners(gray, checkerboard, cv2.CALIB_CB_ADAPTIVE_THRESH + cv2.CALIB_CB_FAST_CHECK + cv2.CALIB_CB_NORMALIZE_IMAGE)

    # 코너를 찾았다면 리스트에 추가
    if ret == True:
        objpoints.append(objp)
        
        # 코너 좌표 정밀화 (Subpixel accuracy)
        corners2 = cv.cornerSubPix(gray, corners, (11, 11), (-1, -1), criteria)
        imgpoints.append(corners2)

        # 찾은 코너를 화면에 그려서 확인
        cv.drawChessboardCorners(img, checkerboard, corners2, ret)
        cv.imshow('Find Corners', img)
        cv.waitKey(500)
    else:
        print("인식실패")

cv.destroyAllWindows()

# 카메라 캘리브레이션 수행
# ret: 오차, mtx: 카메라 매트릭스, dist: 왜곡 계수, rvecs: 회전 벡터, tvecs: 이동 벡터
ret,mtx,dist,rvecs,tvecs = cv.calibrateCamera(objpoints,imgpoints,gray.shape[::-1], None, None)

# 왜곡 보정 테스트 
img = cv.imread(images[0])
h, w = img.shape[:2]
newcameramtx, roi = cv.getOptimalNewCameraMatrix(mtx, dist, (w, h), 1, (w, h))

# 왜곡 보정 수행
dst = cv.undistort(img, mtx, dist, None, newcameramtx)

# 결과물 자르기
x, y, w, h = roi
dst = dst[y:y+h, x:x+w]

cv.imshow('Original', img)
cv.imshow('Undistorted Result', dst)
cv.waitKey(0)
cv.destroyAllWindows()
